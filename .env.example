# Porta HTTP do servidor (padrão: 19742)
SERVER_PORT=19742

# Caminho do arquivo SQLite dentro do container.
# O docker-compose monta ${HOME}/.local/share/financas (host) em
# /root/.local/share/financas (container), então o default já funciona
# sem precisar definir esta variável.
DB_PATH=/root/.local/share/financas/financas.sqlite

# ── Backup / Google Drive ─────────────────────────────────────────
# Liga/desliga a feature. Se false ou credenciais ausentes, o app sobe sem backup.
DRIVE_SYNC_ENABLED=true

# Credenciais OAuth2 do app (ver guia de configuração).
DRIVE_CLIENT_ID=SEU_CLIENT_ID.apps.googleusercontent.com
DRIVE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Refresh token: OPCIONAL. O recomendado é rodar `./server -authorize` uma vez
# (gera ~/.config/financas/token.json e o app autentica sozinho daí em diante).
# Preencha aqui apenas se preferir fornecer o token manualmente (fallback).
DRIVE_REFRESH_TOKEN=

DRIVE_FOLDER_NAME=Financas
DRIVE_LATEST_FILENAME=financas-latest.sqlite

# Retenção de versões datadas (0 = só a "latest", sem histórico).
DRIVE_BACKUP_RETENTION=30

# Autosave periódico em minutos (0 = desabilitado; só manual + shutdown).
BACKUP_AUTOSAVE_INTERVAL=0
